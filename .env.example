# ===========================================
# Flask Configuration
# ===========================================
SECRET_KEY=change-me
DATABASE_URI=postgresql://user:password@localhost:5432/naps_dev

# ===========================================
# JWT
# ===========================================
JWT_SECRET_KEY=change-me

# ===========================================
# SMTP (Gmail)
# ===========================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ===========================================
# Cloudinary
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# Staging / Test (used by pytest & CI)
# ===========================================
TEST_SECRET_KEY=change-me
TEST_DATABASE_URI=postgresql://user:password@localhost:5432/naps_test

# ===========================================
# Production (used by Docker / Coolify)
# ===========================================
PROD_SECRET_KEY=change-me
PROD_DATABASE_URI=postgresql://user:password@host:5432/naps_prod
