# ===========================================
# Flask Configuration
# ===========================================
# Application secret key (used for sessions, CSRF protection, etc.)
SECRET_KEY=your-secret-key-here

# Flask environment: development, staging, or production
FLASK_ENV=development

# ===========================================
# Database Configuration
# ===========================================
# Development database URI (PostgreSQL format)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URI=postgresql://user:password@localhost:5432/naps_dev

# Test database URI
TEST_DATABASE_URI=postgresql://user:password@localhost:5432/naps_test

# Production database URI
PROD_DATABASE_URI=postgresql://user:password@host:5432/naps_prod

# ===========================================
# JWT Authentication
# ===========================================
# Secret key for signing JWT tokens
JWT_SECRET_KEY=your-jwt-secret-key-here

# ===========================================
# API Keys
# ===========================================
# Main API key for authenticating requests (shared across clients)
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# SMTP server settings (using Gmail as example)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Note: For Gmail, you need to use an "App Password"
# Go to Google Account > Security > 2-Step Verification > App Passwords

# ===========================================
# Cloudinary (File Storage)
# ===========================================
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# AWS S3 (Optional - for additional file storage)
# ===========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# Use specific origins in production
# Example: CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# ===========================================
# Environment-Specific Secrets
# ===========================================
# Separate secret keys for different environments
TEST_SECRET_KEY=your-test-secret-key
PROD_SECRET_KEY=your-prod-secret-key

# ===========================================
# Quick Setup Guide for New Developers
# ===========================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update the values:
#    - SECRET_KEY: Run `python -c "import secrets; print(secrets.token_hex(32))"`
#    - DATABASE_URI: Create a local PostgreSQL database or use a free tier like Neon
#    - JWT_SECRET_KEY: Run `python -c "import secrets; print(secrets.token_hex(32))"`
#    - API_KEY: Run `python -c "import secrets; token_hex(32))"`
#    - EMAIL_USER: Your Gmail address
#    - EMAIL_PASSWORD: Generate an App Password from your Google Account
#    - Cloudinary: Sign up at https://cloudinary.com and get credentials from dashboard
#
# 3. Install dependencies:
#    pip install -r requirements.txt
#
# 4. Run migrations:
#    flask db upgrade
#
# 5. Start the server:
#    flask run
#
# ===========================================
